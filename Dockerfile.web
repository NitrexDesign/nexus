FROM node:22-alpine AS base

# Install dependencies only when needed
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Install dependencies
COPY web/package.json web/pnpm-lock.yaml* ./
RUN if [ -f pnpm-lock.yaml ]; then pnpm i --frozen-lockfile; else pnpm i; fi

# Rebuild the source code only when needed
FROM base AS builder
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY --from=deps /app/node_modules ./node_modules
COPY web/ .

RUN pnpm run build

# Install production-only dependencies and remove heavy build-time transitive deps
# that vinext drags in but doesn't need for `vinext start`
RUN rm -rf node_modules && pnpm i --frozen-lockfile --prod && \
	cd node_modules/.pnpm && \
	rm -rf next@* @next+swc* typescript@* @img+sharp* \
	sharp@* caniuse-lite@* webpack@* \
	babel-plugin-react-compiler@* @babel* @vercel+og@*

# Production image
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy build output and production dependencies
COPY --from=builder --chown=nextjs:nodejs /app/dist ./dist
COPY --from=builder --chown=nextjs:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=nextjs:nodejs /app/package.json ./package.json
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node_modules/.bin/vinext", "start"]
